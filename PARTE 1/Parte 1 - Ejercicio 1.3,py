'''
Ejercicio 1.3 — Replica el ejemplo
Escribe y ejecuta el siguiente código sobre asignación múltiple de variables:
'''

# Asignación múltiple 
a, b, c = 10, 20, 30   #se asignan tres valores a tres variable en una sola linea
print(a, b, c)         # Se imprimen los valores de a,b y 10 20 30

# Intercambio de valores swap (en C necesitarías una variable temporal)
#se asignan valores iniciales
x = 100
y = 200
#intercambio sin variable auxiliar
x, y = y, x
#Ahora x vale 200 y y vale 100
print(x, y)             # Imprime 200 100

# Misma asignación a varias variables
#Se asigna el mismo valor (0) a tres variables 
m = n = p = 0
#Todas las variables tiene el mismo valor
print(m, n, p)          # Imprime 0 0 0
